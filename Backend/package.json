{
  "name": "tempos-api",
  "version": "0.1.0",
  "description": "Tempos time tracking API — Node.js + Express + TypeORM",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typeorm": "typeorm",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "typeorm migration:run",
    "migration:revert": "typeorm migration:revert",
    "seed": "tsx src/scripts/seed.ts",
    "gdpr:purge": "tsx src/scripts/gdpr-purge.ts",
    "gcp:secrets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup_secret_manager.ps1",
    "gcp:scheduler": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup_cloud_scheduler.ps1",
    "gcp:deploy-worker": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy_retrain_worker.ps1",
    "github:bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap_github_repo.ps1",
    "github:secrets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/push_github_secrets.ps1",
    "test": "node --test --test-concurrency=1 --test-reporter=tap \"dist/tests/**/*.test.js\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/secret-manager": "^6.1.1",
    "@simplewebauthn/server": "^13.3.0",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "puppeteer": "^24.42.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.21",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.11.5",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^9.0.7",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "sqlite3": "^5.1.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
